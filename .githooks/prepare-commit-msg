#!/usr/bin/env bash

# Auto-bumps VERSION for PR branches using commit-message prefixes.
# Exactly one bump is allowed per branch/PR. If VERSION already changed
# since branch divergence from main/master, this hook does nothing.

COMMIT_MSG_FILE="${1:-}"
COMMIT_SOURCE="${2:-}"

if [[ -z "$COMMIT_MSG_FILE" || ! -f "$COMMIT_MSG_FILE" ]]; then
  exit 0
fi

# Only run on normal commits (interactive or -m).
if [[ -n "$COMMIT_SOURCE" && "$COMMIT_SOURCE" != "message" ]]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
BUMP_SCRIPT="$REPO_ROOT/scripts/bump_version.py"
VERSION_FILE="$REPO_ROOT/VERSION"

if [[ ! -f "$BUMP_SCRIPT" || ! -f "$VERSION_FILE" ]]; then
  exit 0
fi

CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
if [[ -z "$CURRENT_BRANCH" || "$CURRENT_BRANCH" == "HEAD" ]]; then
  exit 0
fi

# PR-oriented rule: skip direct commits on main/master.
if [[ "$CURRENT_BRANCH" == "main" || "$CURRENT_BRANCH" == "master" ]]; then
  exit 0
fi

FIRST_LINE="$(head -n 1 "$COMMIT_MSG_FILE" 2>/dev/null | tr -d '\r')"
FIRST_LINE_LOWER="$(echo "$FIRST_LINE" | tr '[:upper:]' '[:lower:]')"

if [[ ! "$FIRST_LINE_LOWER" =~ ^(release|major|feature|fix)\( ]]; then
  exit 0
fi

BASE_REF=""
for candidate in "origin/main" "origin/master" "main" "master"; do
  if git rev-parse --verify --quiet "$candidate" >/dev/null; then
    BASE_REF="$candidate"
    break
  fi
done

MERGE_BASE=""
if [[ -n "$BASE_REF" ]]; then
  MERGE_BASE="$(git merge-base HEAD "$BASE_REF" 2>/dev/null || true)"
fi
if [[ -z "$MERGE_BASE" ]]; then
  MERGE_BASE="$(git rev-list --max-parents=0 HEAD | tail -n 1)"
fi

# One bump max per branch/PR: if any commit since divergence already
# touched VERSION, skip all future auto-bumps.
if git log --format="%H" "$MERGE_BASE"..HEAD -- VERSION 2>/dev/null | grep -q "."; then
  exit 0
fi

CURRENT_VERSION="$(tr -d '[:space:]' < "$VERSION_FILE")"
BASE_VERSION="$(git show "$MERGE_BASE:VERSION" 2>/dev/null | tr -d '[:space:]' || true)"
if [[ -z "$BASE_VERSION" ]]; then
  BASE_VERSION="$CURRENT_VERSION"
fi

# One bump max per branch/PR.
if [[ "$CURRENT_VERSION" != "$BASE_VERSION" ]]; then
  exit 0
fi

OUTPUT="$(python3 "$BUMP_SCRIPT" "$FIRST_LINE" "$CURRENT_VERSION" 2>&1)"
EXIT_CODE=$?

if [[ $EXIT_CODE -eq 0 ]] && echo "$OUTPUT" | grep -q "Version bumped:"; then
  git add "$VERSION_FILE" >/dev/null 2>&1 || true
  echo "$OUTPUT"
fi

exit 0
